---
interface Props {
  name: string;
  description: string;
  language: string;
  repo: string;
  docs?: string;
  logo?: string;
}

const { name, description, language, repo, docs, logo } = Astro.props;

const languageColors: Record<string, string> = {
  Python: '#3572A5',
  Rust: '#DEA584',
  TypeScript: '#3178C6',
};

const color = languageColors[language] || '#888';
const docHref = docs || repo;
const sameTarget = docHref === repo;
---

<div class="project-card">
  <div class="project-header">
    <div class="project-name">
      {logo && <span class="project-logo" style={`-webkit-mask-image: url(${logo}); mask-image: url(${logo})`} role="img" aria-hidden="true" />}
      <h3><a href={docHref}>{name}</a></h3>
    </div>
    <span class="language-badge" style={`--badge-color: ${color}`}>{language}</span>
  </div>
  <p>{description}</p>
  <div class="project-links">
    {!sameTarget && <a href={docHref}>Documentation</a>}
    <a href={repo}>GitHub &rarr;</a>
  </div>
</div>

<style>
  .project-card {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--sl-color-black);
    transition: all 0.2s ease;
    position: relative;
  }

  .project-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: var(--badge-color, var(--sl-color-accent));
    border-radius: 8px 0 0 8px;
    opacity: 0;
    transition: opacity 0.2s;
  }

  .project-card:hover {
    border-color: var(--sl-color-gray-4);
    background: var(--sl-color-gray-6);
  }

  .project-card:hover::before {
    opacity: 1;
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.5rem;
  }

  .project-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-logo {
    display: inline-block;
    width: 18px;
    height: 36px;
    background: currentColor;
    -webkit-mask-size: contain;
    mask-size: contain;
    -webkit-mask-repeat: no-repeat;
    mask-repeat: no-repeat;
    -webkit-mask-position: center;
    mask-position: center;
    opacity: 0.85;
  }

  .project-header h3 {
    margin: 0;
    font-size: 1rem;
    font-family: var(--sl-font-mono);
    font-weight: 600;
  }

  .project-header a {
    text-decoration: none;
    color: var(--sl-color-white);
    transition: color 0.2s;
  }

  .project-header a:hover {
    color: var(--sl-color-text-accent);
  }

  .language-badge {
    font-size: 0.65rem;
    padding: 0.15rem 0.55rem;
    border-radius: 4px;
    background: transparent;
    color: var(--badge-color);
    font-weight: 600;
    letter-spacing: 0.03em;
    border: 1px solid var(--badge-color);
    font-family: var(--sl-font-mono);
  }

  p {
    color: var(--sl-color-gray-2);
    margin: 0.25rem 0 0.75rem;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .project-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.75rem;
    font-size: 0.8rem;
    font-family: var(--sl-font-mono);
  }

  .project-links a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .project-links a:hover {
    text-decoration: underline;
  }
</style>
